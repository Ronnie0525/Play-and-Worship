{
  "name": "Play & Worship",
  "short_name": "P&Worship",
  "description": "Modern worship presentation — songs, scripture, media, and a dedicated live projector.",
  "start_url": "./app/",
  "scope": "./",
  "display": "standalone",
  "orientation": "landscape",
  "background_color": "#08090f",
  "theme_color": "#08090f",
